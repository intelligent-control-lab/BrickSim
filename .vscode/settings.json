{
    "files.exclude": {
        "**/*.egg-info": true,
        "**/.thumbs": true,
        "logs": true,
        "outputs": true,
    },
    "files.watcherExclude": {
        "logs": true,
        "outputs": true,
    },
    "files.associations": {
        "*.kit": "ini",
    },
    "python.analysis.languageServerMode": "full",
    "C_Cpp.intelliSenseEngine": "disabled",
    "debug.onTaskErrors": "debugAnyway",
    "cmake.cmakePath": "${workspaceFolder}/_toolchain/cmake-4.2.0-rc2-linux-x86_64/bin/cmake",
    "cmake.sourceDirectory": "${workspaceFolder}/native",
    "cmake.useCMakePresets": "always",
    "cmake.revealLog": "never",
    "clangd.path": "${workspaceFolder}/_toolchain/llvm-22+0246f33/bin/clangd",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/native/.build/dev",
        "--header-insertion=never",
    ],
}
