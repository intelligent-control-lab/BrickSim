{
    "files.exclude": {
        "**/*.egg-info": true,
        "**/.thumbs": true,
        "**/.build": true,
        "logs": true,
        "outputs": true,
    },
    "files.watcherExclude": {
        "logs": true,
        "outputs": true,
    },
    "files.associations": {
        "*.kit": "ini",
    },
    "python.analysis.languageServerMode": "full",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/source/lego_assemble/cpp",
        "--header-insertion=never",
    ],
    "C_Cpp.intelliSenseEngine": "disabled",
    "debug.onTaskErrors": "debugAnyway"
}
