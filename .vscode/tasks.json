{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Extension",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "source ${workspaceFolder}/.venv/bin/activate && python -m pip install -e extension/source/lego_assemble"
      ],
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
