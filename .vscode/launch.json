{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "IsaacSim: Attach",
            "type": "debugpy",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "justMyCode": false,
        },
        {
            "name": "IsaacSim: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/isaacsim/python.sh",
        },
        {
            "name": "Train LiftBrick",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/extension/scripts/skrl_train.py",
            "args": ["--task", "Lego-LiftBrick-v0", "--num_envs", "32"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/isaacsim/python.sh",
        },
    ]
}
