{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Attach 5678",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "justMyCode": false,
            "presentation": {
                "hidden": true
            }
        },
        {
            "name": "C++: Attach IsaacSim",
            "type": "lldb",
            "request": "attach",
            "program": "${workspaceRoot}/.venv/bin/python",
            "pid": "${input:pid_isaacsim}",
            "stopOnEntry": false,
            "initCommands": [
                "process handle --stop false --notify false SIGWINCH"
            ],
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
        },
        {
            "name": "C++: CMake Debug",
            "type": "lldb",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopOnEntry": false,
            "cwd": "${workspaceFolder}",
            "env": {
                "PATH": "${env:PATH}:${command:cmake.getLaunchTargetDirectory}",
            },
        }
    ],
    "compounds": [
        {
            "name": "Debug Python",
            "configurations": [
                "Python: Attach 5678"
            ],
            "stopAll": true,
            "preLaunchTask": "Launch IsaacSim"
        },
        {
            "name": "Debug Python (Current File)",
            "configurations": [
                "Python: Attach 5678"
            ],
            "stopAll": true,
            "preLaunchTask": "Launch IsaacSim & Execute Current File"
        },
        {
            "name": "Debug C++ & Python",
            "configurations": [
                "Python: Attach 5678",
                "C++: Attach IsaacSim"
            ],
            "stopAll": true,
            "preLaunchTask": "Launch IsaacSim"
        },
        {
            "name": "Debug C++ & Python (Current File)",
            "configurations": [
                "Python: Attach 5678",
                "C++: Attach IsaacSim"
            ],
            "stopAll": true,
            "preLaunchTask": "Launch IsaacSim & Execute Current File"
        }
    ],
    "inputs": [
        {
            "id": "pid_isaacsim",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "pgrep -nx isaacsim",
                "useFirstResult": true
            }
        }
    ]
}
